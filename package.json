{
  "name": "cortex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "npx tsx scripts/sync.ts",
    "sync:watch": "npx tsx scripts/sync.ts --watch",
    "auto-tag": "npx tsx scripts/auto-tag.ts",
    "sync:pull": "set -a && . ./.env.local && set +a && npx tsx scripts/sync-from-redis.ts",
    "sync:install": "bash scripts/install-service.sh install",
    "sync:uninstall": "bash scripts/install-service.sh uninstall",
    "sync:logs": "journalctl --user -u cortex-sync -f"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/react": "^3.0.118",
    "@anthropic-ai/sdk": "^0.78.0",
    "@elevenlabs/elevenlabs-js": "^2.39.0",
    "@tavily/core": "^0.7.2",
    "@types/bcrypt": "^6.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/qrcode": "^1.5.6",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "ai": "^6.0.116",
    "bcrypt": "^6.0.0",
    "chokidar": "^5.0.0",
    "d3-force": "^3.0.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.1",
    "next": "16.1.6",
    "otplib": "^13.3.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "vectra": "^0.12.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
